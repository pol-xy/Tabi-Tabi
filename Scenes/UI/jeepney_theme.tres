[gd_resource type="Theme" load_steps=8 format=3]

; Palette reference (keep in sync with any script-side Color constants):
;   Ink / border   #3A2718
;   Cardboard fill #E8D2A6
;   Cream fill     #F5E9C8
;   Jeepney yellow #FFC93C
;   Jeepney red    #C62E2A
;   Satisfied green#2A8C47

[sub_resource type="StyleBoxFlat" id="StyleBoxFlat_cardboard"]
bg_color = Color(0.910, 0.824, 0.651, 1)
border_width_left = 3
border_width_top = 3
border_width_right = 3
border_width_bottom = 3
border_color = Color(0.227, 0.153, 0.094, 1)
corner_radius_top_left = 10
corner_radius_top_right = 10
corner_radius_bottom_right = 10
corner_radius_bottom_left = 10
shadow_color = Color(0, 0, 0, 0.25)
shadow_size = 4
shadow_offset = Vector2(0, 3)


[resource]
default_font_size = 16
Panel/styles/panel = SubResource("StyleBoxFlat_cardboard")
PanelContainer/styles/panel = SubResource("StyleBoxFlat_cardboard")
Button/styles/normal = SubResource("StyleBoxFlat_button_normal")
Button/styles/hover = SubResource("StyleBoxFlat_button_hover")
Button/styles/pressed = SubResource("StyleBoxFlat_button_pressed")
Button/styles/disabled = SubResource("StyleBoxFlat_button_normal")
Button/styles/focus = SubResource("StyleBoxEmpty_focus")
Button/colors/font_color = Color(0.227, 0.153, 0.094, 1)
Button/colors/font_hover_color = Color(0.227, 0.153, 0.094, 1)
Button/colors/font_pressed_color = Color(0.961, 0.914, 0.784, 1)
Button/font_sizes/font_size = 12
Label/colors/font_color = Color(0.227, 0.153, 0.094, 1)
Label/font_sizes/font_size = 16
RichTextLabel/colors/default_color = Color(0.227, 0.153, 0.094, 1)
RichTextLabel/font_sizes/normal_font_size = 17
ProgressBar/styles/background = SubResource("StyleBoxFlat_progress_bg")
ProgressBar/styles/fill = SubResource("StyleBoxFlat_progress_fill")
ProgressBar/colors/font_color = Color(0.227, 0.153, 0.094, 1)
